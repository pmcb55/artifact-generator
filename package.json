{
  "name": "@inrupt/artifact-generator",
  "version": "4.0.0",
  "description": "A generator for building artifacts (e.g. Java JARs, NPM modules, etc.) from RDF vocabularies.",
  "main": "dist/index.js",
  "bin": {
    "artifact-generator": "dist/index.js"
  },
  "files": [
    "dist/",
    "template/"
  ],
  "type": "module",
  "scripts": {
    "test": "npm run format && npm run lint && npm run typecheck && jest --forceExit --detectOpenHandles",
    "start": "node bin/artifact-generator.js",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.{js,ts}\" \"test/resources/**/*.yml\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "preversion": "npm test"
  },
  "author": "Inrupt, Inc.",
  "contributors": [
    "Jarlath Holleran (https://github.com/jholleran)",
    "Pat McBennett (https://github.com/pmcb55)",
    "Nicolas Seydoux (https://github.com/NSeydoux)",
    "Andy Davidson (contractor with Inrupt)"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/inrupt/artifact-generator.git"
  },
  "license": "MIT",
  "preferGlobal": true,
  "keywords": [],
  "dependencies": {
    "@rdfjs/fetch-lite": "^3.3.0",
    "@rdfjs/parser-jsonld": "^2.1.3",
    "@rdfjs/parser-n3": "^2.1.0",
    "@rdfjs/sink-map": "^2.0.1",
    "axios": "^1.10.0",
    "chokidar": "^5.0.0",
    "debug": "^4.4.1",
    "del": "^8.0.1",
    "glob": "^13.0.0",
    "handlebars": "^4.7.7",
    "inquirer": "^8.2.5",
    "js-yaml": "^4.1.0",
    "mock-local-storage": "^1.1.20",
    "moment": "^2.29.3",
    "rdf-ext": "^2.6.0",
    "rdfa-streaming-parser": "^3.0.1",
    "rdfxml-streaming-parser": "^3.1.0",
    "rimraf": "^6.0.1",
    "string-to-stream": "^3.0.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/inquirer": "^8.2.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "baseline-browser-mapping": "^2.10.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^17.0.0",
    "jest": "^30.0.4",
    "prettier": "3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "<rootDir>/generated/",
      "<rootDir>/test/Generated/"
    ],
    "collectCoverage": true,
    "coverageReporters": [
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 100,
        "functions": 100,
        "statements": 100,
        "branches": 100
      }
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node",
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true
          },
          "diagnostics": false,
          "babelConfig": true
        }
      ],
      "^.+\\.[cm]?js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/(?!(@rdfjs|rdf-ext|chokidar|readdirp|del|globby|is-path-cwd|is-path-inside|unicorn-magic|p-map|path-type|yargs|y18n|yargs-parser|cliui|@isaacs|glob|path-scurry|minipass|jackspeak|foreground-child|package-json-from-dist|rimraf|@sindresorhus|stream-chunks|grapoi|duplex-to|node-fetch|data-uri-to-buffer|fetch-blob|formdata-polyfill|nodeify-fetch|file-fetch|proto-fetch|presentable-error|get-package-type|ky|axios|get-east-asian-width)/)"
    ],
    "moduleNameMapper": {
      "^unicorn-magic$": "<rootDir>/node_modules/unicorn-magic/node.js",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "moduleFileExtensions": [
      "ts",
      "mjs",
      "cjs",
      "js",
      "json",
      "node"
    ]
  },
  "bugs": {
    "url": "https://github.com/inrupt/artifact-generator/issues"
  },
  "homepage": "https://github.com/inrupt/artifact-generator#readme",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
